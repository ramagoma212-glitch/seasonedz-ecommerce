# Copy this file to .env for local development (Vite loads .env
# automatically — no extra setup needed). Not secret: this is just the
# local backend API's base URL, safe to see in browser dev tools since
# every frontend build already ships it to the client either way.
VITE_API_BASE_URL=http://localhost:5000/api

# Feature flag (Version 3, Milestone 23) — shows PayFast as a
# selectable checkout option when "true", "Coming Soon" (disabled)
# otherwise. Default must stay "false" until the backend's own
# PAYFAST_ENABLED is intentionally turned on too — this flag only
# controls what the UI *offers*; the backend independently re-checks
# and rejects paymentMethod: PAYFAST if its own PAYFAST_ENABLED is off,
# regardless of what this flag says. Never put PayFast merchant
# secrets (merchant ID/key/passphrase) in any VITE_-prefixed variable —
# those are baked into the public client bundle. See
# backend/PAYFAST_SETUP.md.
VITE_PAYFAST_ENABLED=false
