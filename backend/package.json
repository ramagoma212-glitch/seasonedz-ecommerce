{
  "name": "seasonedz-backend",
  "private": true,
  "version": "0.1.0",
  "description": "Seasonedz Group backend API (Version 2) — Express + TypeScript + Prisma, backed by a real Supabase PostgreSQL database.",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "prisma": "^5.19.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  }
}
