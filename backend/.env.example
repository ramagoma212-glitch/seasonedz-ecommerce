# Copy this file to .env and fill in real values locally.
# .env is git-ignored (via the root .gitignore) — never commit real secrets.

NODE_ENV=development
PORT=5000

# Required — a real Supabase/PostgreSQL connection string.
# DATABASE_URL: the pooled (pgbouncer) connection, used by the app at runtime.
# DIRECT_URL: the direct (non-pooled) connection, used only by Prisma Migrate.
# Never commit real values here — fill them in only in your local .env.
DATABASE_URL=
DIRECT_URL=

# Used for CORS — must match the frontend's dev server URL. Required in
# every environment; in production this must be the real deployed
# frontend origin (no localhost fallback is offered when NODE_ENV=production).
FRONTEND_URL=http://localhost:5173

# Optional second allowed CORS origin — e.g. the deployed GitHub Pages
# URL, so both the local dev frontend and the live site can call this
# API. Leave empty if there's only one frontend origin to allow.
# Example: FRONTEND_PRODUCTION_URL=https://ramagoma212-glitch.github.io
FRONTEND_PRODUCTION_URL=

# --- PayFast (Version 3, Milestone 20 — sandbox configuration only) ---
# No payment initiation or ITN handling exists yet. These variables are
# read and validated at startup so the config is ready ahead of that
# work, but nothing calls PayFast with them yet. See
# backend/PAYFAST_SETUP.md for full details.
#
# Feature flag: real PayFast checkout stays blocked (POST /api/orders
# rejects paymentMethod: PAYFAST) until this is explicitly set to
# "true", which won't happen until payment initiation + ITN
# verification are actually built and tested.
PAYFAST_ENABLED=false

# "sandbox" or "production" — selects which PayFast process URL is used
# once payment initiation exists. Always use "sandbox" until real
# production credentials and a fully tested ITN flow are in place.
PAYFAST_MODE=sandbox

# From your PayFast merchant account (sandbox or production — never
# commit real values here, only in your local .env).
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=

# Optional — only set if your PayFast account has a passphrase
# configured. Leave empty otherwise.
PAYFAST_PASSPHRASE=

# This backend's own public URL (e.g. the live Render URL), used to
# build PAYFAST_NOTIFY_URL below. Required once PayFast is enabled.
BACKEND_PUBLIC_URL=

# Where PayFast redirects the customer's browser after payment.
# Frontend URLs — not proof of payment by themselves, see
# backend/PAYFAST_SETUP.md.
PAYFAST_RETURN_URL=
PAYFAST_CANCEL_URL=

# Backend ITN endpoint PayFast calls server-to-server. Should be built
# from BACKEND_PUBLIC_URL once that endpoint exists.
PAYFAST_NOTIFY_URL=

# --- PayFast source verification hardening (Version 4, Milestone 29; ---
# --- strategy updated Version 5, Milestone 35) ---
# Safe to leave exactly as-is for local development and sandbox
# testing. See backend/VERSION_4_PAYFAST_SOURCE_VERIFICATION.md,
# backend/PAYFAST_SETUP.md, and
# VERSION_5_PAYFAST_VERIFICATION_STRATEGY_UPDATE.md for full detail on
# what each does and the current production requirement.

# off | monitor | enforce. "off" never runs the DNS source check.
# "monitor" runs it and logs the pass/fail outcome, but never blocks on
# a failure — safe to use anywhere, including a real deployment, to
# gather evidence before ever enforcing. "enforce" blocks on failure,
# exactly like the old PAYFAST_VERIFY_SOURCE=true — only appropriate
# once "monitor" mode's own logs show it reliably passing against real
# PayFast traffic on the actual hosting environment in use.
PAYFAST_SOURCE_VERIFICATION_MODE=off

# Legacy boolean — still read as a fallback only when
# PAYFAST_SOURCE_VERIFICATION_MODE above isn't set at all ("true" maps
# to "enforce", "false"/unset maps to "off"). New setups should use
# PAYFAST_SOURCE_VERIFICATION_MODE instead.
PAYFAST_VERIFY_SOURCE=false

# When "true", the notify handler POSTs the received ITN data back to
# PayFast's own validation endpoint and requires a "VALID" response
# before trusting it — PayFast's own recommended custom-integration
# confirmation step. Required (documentation, not enforced here) before
# real production PayFast credentials are ever used — its acceptance
# path is already proven (Milestone 30).
PAYFAST_VALIDATE_SERVER=false

# When "true" or "1", trusts exactly one reverse-proxy hop
# (app.set("trust proxy", 1)) so req.ip reflects the real original
# client instead of the proxy's own address — needed on Render (one
# hop) or behind a tunnel for PAYFAST_SOURCE_VERIFICATION_MODE (when not
# "off") to see the real caller. Leave "false" for plain local
# development with no proxy in front of the backend.
TRUST_PROXY=false

# --- Email (Version 3, Milestone 24 — preparation only) ---
# No real email is sent yet, and nothing here is wired up to actually
# fire on order/payment/enquiry events yet — see backend/EMAIL_SETUP.md.
# Safe to leave everything below exactly as-is; the backend starts
# fine with no email credentials at all as long as EMAIL_ENABLED=false.
EMAIL_ENABLED=false

# "console" (log safe metadata only, never send anything — the only
# supported value right now) or a future real provider name (e.g.
# "resend", "sendgrid", "smtp") once that integration actually exists.
EMAIL_PROVIDER=console

EMAIL_FROM_NAME=Seasonedz Group

# Required only once EMAIL_ENABLED=true.
EMAIL_FROM_ADDRESS=
ADMIN_NOTIFICATION_EMAIL=

# Optional future provider credentials — not read or required by
# anything yet. Fill in only once a real provider is actually
# integrated in a later milestone; never commit real values.
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Admin auth (Version 7, Milestone 58 — foundation only) ---
# No admin route is linked from the public site, and no real admin
# user exists in production yet — see
# VERSION_7_ADMIN_AUTH_FOUNDATION_RESULT.md.

# Signs the admin session cookie (defence-in-depth against cookie
# tampering — the session itself is still independently verified
# server-side against a hashed token either way). Safe to leave empty
# locally: the backend falls back to a random, process-only secret if
# unset, which just means sessions won't survive a restart until a
# real value is set. Never commit a real value here.
ADMIN_SESSION_SECRET=

# Only read by the manual bootstrap script
# (prisma/scripts/setupAdminUser.ts, run via `npm run admin:setup`),
# never by the running server. Supply real values only as inline
# environment variables when deliberately running that script — never
# write real values to this file or any other tracked file.
ADMIN_SETUP_EMAIL=
ADMIN_SETUP_PASSWORD=

# --- Product image upload (Version 7, Milestone 69 — backend only, ---
# --- no admin upload UI yet) ---
# See VERSION_7_PRODUCT_IMAGE_UPLOAD_BACKEND_RESULT.md for full detail.
# Both SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY must be set for image
# upload to work — until then, POST/GET/PATCH
# /api/admin/products/:id/images respond with a clear "not configured"
# error and every other route is unaffected. Never commit real values
# here, and never paste the service role key into chat or any tracked
# file — add it directly in Render's environment settings when ready.

# Your Supabase project's API URL (Project Settings -> API), e.g.
# https://<project-ref>.supabase.co. Not the database connection
# string above — a different value from the same Supabase project.
SUPABASE_URL=

# Supabase's "service_role" key (Project Settings -> API) — treat this
# exactly like a database admin password. It bypasses row-level
# security and must only ever be read by this backend on Render, never
# sent to or stored in the frontend, never logged.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket name for product images. Defaults to "product-images"
# if unset — only set this if a different bucket name is intentionally
# needed. The bucket itself is not created by this backend; it must be
# created separately in the Supabase dashboard once approved.
PRODUCT_IMAGES_BUCKET=product-images

# --- Courier Guy (Version 7, Milestone 108 — admin-only RATE QUOTE ---
# --- only; no booking/shipment endpoint is ever called) ---
# Never commit real values here, and never paste the API key into chat
# or any tracked file — add it directly in Render's environment
# settings when ready. See backend/DELIVERY_SETUP.md.

# Feature flag: the admin quote route stays disabled (clear 503
# response, no network call) until this is explicitly "true". The
# backend must keep starting normally with this "false" and no Courier
# Guy variables set at all.
COURIER_GUY_ENABLED=false

# From Courier Guy's developer portal (Integrations > API Keys).
# Sandbox and production use different keys — never commit either.
COURIER_GUY_API_KEY=

# Sandbox: https://api.shiplogic.com
# Production (documented portal endpoint): https://api.portal.thecourierguy.co.za
COURIER_GUY_BASE_URL=https://api.shiplogic.com

# Seasonedz Group's own collection ("from") address — required only
# once COURIER_GUY_ENABLED=true. Leave empty while disabled.
COURIER_GUY_COLLECTION_COMPANY=
COURIER_GUY_COLLECTION_STREET_ADDRESS=
COURIER_GUY_COLLECTION_LOCAL_AREA=
COURIER_GUY_COLLECTION_CITY=
COURIER_GUY_COLLECTION_ZONE=
COURIER_GUY_COLLECTION_COUNTRY=ZA
COURIER_GUY_COLLECTION_CODE=

# "business" is the only realistic value for a collection address that
# is never a residential pickup.
COURIER_GUY_COLLECTION_TYPE=business

# Safe starting defaults for a small book/marker-pack parcel — always
# adjustable by the admin per-quote in the UI before requesting a rate.
COURIER_GUY_DEFAULT_PARCEL_WEIGHT_KG=0.3
COURIER_GUY_DEFAULT_PARCEL_LENGTH_CM=30
COURIER_GUY_DEFAULT_PARCEL_WIDTH_CM=22
COURIER_GUY_DEFAULT_PARCEL_HEIGHT_CM=3
