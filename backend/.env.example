# Copy this file to .env and fill in real values locally.
# .env is git-ignored (via the root .gitignore) — never commit real secrets.

NODE_ENV=development
PORT=5000

# Required — a real Supabase/PostgreSQL connection string.
# DATABASE_URL: the pooled (pgbouncer) connection, used by the app at runtime.
# DIRECT_URL: the direct (non-pooled) connection, used only by Prisma Migrate.
# Never commit real values here — fill them in only in your local .env.
DATABASE_URL=
DIRECT_URL=

# Used for CORS — must match the frontend's dev server URL. Required in
# every environment; in production this must be the real deployed
# frontend origin (no localhost fallback is offered when NODE_ENV=production).
FRONTEND_URL=http://localhost:5173

# Optional second allowed CORS origin — e.g. the deployed GitHub Pages
# URL, so both the local dev frontend and the live site can call this
# API. Leave empty if there's only one frontend origin to allow.
# Example: FRONTEND_PRODUCTION_URL=https://ramagoma212-glitch.github.io
FRONTEND_PRODUCTION_URL=
