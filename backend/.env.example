# Copy this file to .env and fill in real values locally.
# .env is git-ignored (via the root .gitignore) — never commit real secrets.

NODE_ENV=development
PORT=5000

# Not required for this milestone — no database connection is made yet.
# Will be a real PostgreSQL connection string in a future milestone.
DATABASE_URL=

# Used for CORS — must match the frontend's dev server URL.
FRONTEND_URL=http://localhost:5173
