# Example production environment values — not secret. VITE_API_BASE_URL
# is safe to commit/see in browser dev tools either way, since Vite
# ships it to the client in the built JS regardless of where it comes
# from. This file documents the value; the GitHub Actions deploy
# workflow (.github/workflows/deploy.yml) is what actually sets it for
# the real production build — see VERSION_2_INTEGRATION_NOTES.md.
#
# Not auto-loaded by Vite (Vite only auto-loads .env/.env.local/
# .env.production, not .env.production.example) — this file is
# reference/documentation only. To build locally against the live
# Render backend instead of your local one, copy this to
# .env.production and run `npm run build -- --mode production`, or
# simply export VITE_API_BASE_URL before building.
VITE_API_BASE_URL=https://seasonedz-ecommerce.onrender.com/api
